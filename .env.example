# ── Platform list ──────────────────────────────────────────────────────
SAAS_PLATFORMS=fake_ui

# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=debug

# ── Target SaaS Application ────────────────────────────────────
SAAS_FAKE_UI_BASE_URL=http://localhost:5173
SAAS_FAKE_UI_LOGIN_URL=http://localhost:5173/login
SAAS_FAKE_UI_USERNAME=admin
SAAS_FAKE_UI_PASSWORD=password123

# ── Playwright Browser ──────────────────────────────────────────
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=0
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
BROWSER_MAX_CONTEXTS=5

# ── API Authentication (optional) ───────────────────────────────
# API_KEY=your-secret-api-key
