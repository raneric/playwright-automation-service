# ── Server ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=debug

# ── Target SaaS Application ────────────────────────────────────
SAAS_BASE_URL=http://localhost:5173
SAAS_LOGIN_URL=http://localhost:5173/login
SAAS_USERNAME=admin
SAAS_PASSWORD=password123

# ── Playwright Browser ──────────────────────────────────────────
BROWSER_HEADLESS=true
BROWSER_SLOW_MO=0
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
BROWSER_MAX_CONTEXTS=5

# ── API Authentication (optional) ───────────────────────────────
# API_KEY=your-secret-api-key